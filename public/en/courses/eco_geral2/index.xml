      <guid>https://www.ecoaplic.org/en/courses/eco_geral2/biocons/biocons/</guid>
      <description>
&lt;script src=&#34;https://www.ecoaplic.org/rmarkdown-libs/header-attrs/header-attrs.js&#34;&gt;&lt;/script&gt;
&lt;script src=&#34;https://www.ecoaplic.org/rmarkdown-libs/clipboard/clipboard.min.js&#34;&gt;&lt;/script&gt;
&lt;link href=&#34;https://www.ecoaplic.org/rmarkdown-libs/shareon/shareon.min.css&#34; rel=&#34;stylesheet&#34; /&gt;
