@ARTICLE{Brancalion2013705,
author={Brancalion, P.H.S. and Melo, F.P.L. and Tabarelli, M. and Rodrigues, R.R.},
title={Biodiversity persistence in highly humanmodified tropical landscapes depends on ecological restoration},
journal={Tropical Conservation Science},
