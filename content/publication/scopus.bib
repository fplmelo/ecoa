@ARTICLE{Fletcher20189,
author={Fletcher, R.J., Jr and Didham, R.K. and Banks-Leite, C. and Barlow, J. and Ewers, R.M. and Rosindell, J. and Holt, R.D. and Gonzalez, A. and Pardini, R. and Damschen, E.I. and Melo, F.P.L. and Ries, L. and Prevedello, J.A. and Tscharntke, T. and Laurance, W.F. and Lovejoy, T. and Haddad, N.M.},
title={Is habitat fragmentation good for biodiversity?},
journal={Biological Conservation},
year={2018},
volume={226},
pages={9-15},
